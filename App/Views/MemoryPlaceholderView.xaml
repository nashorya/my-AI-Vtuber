<UserControl x:Class="AIVTuber.App.Views.MemoryPlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:AIVTuber.App"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <local:InverseBoolConverter x:Key="InverseBool"/>
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16,12,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ui:Card Grid.Row="0" Padding="10,8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:TextBox Grid.Column="0"
                            PlaceholderText="搜索事实记忆..."
                            Text="{Binding FactSearch, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,0,8,0"/>

                <ui:Button Grid.Column="1" Content="刷新" Margin="0,0,6,0"
                           Appearance="Secondary"
                           Click="OnRefreshClicked"/>

                <ui:Button Grid.Column="2" Content="立即提取" Margin="0,0,6,0"
                           Appearance="Secondary"
                           IsEnabled="{Binding Extracting, Converter={StaticResource InverseBool}}"
                           Click="OnExtractClicked"/>

                <ui:Button Grid.Column="3" Content="切换视图"
                           Appearance="Secondary"
                           Click="OnToggleViewClicked"/>
            </Grid>
        </ui:Card>

        <!-- Facts list -->
        <Grid Grid.Row="1" x:Name="FactsPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="4,0,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="事实内容" Style="{StaticResource ColHeader}" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="1" Text="重要度" Style="{StaticResource ColHeader}"/>
                <TextBlock Grid.Column="2" Text="UID" Style="{StaticResource ColHeader}"/>
                <TextBlock Grid.Column="3" Text="访问时间" Style="{StaticResource ColHeader}"/>
                <TextBlock Grid.Column="4" Text="有效期" Style="{StaticResource ColHeader}"/>
            </Grid>

            <ListBox Grid.Row="1" ItemsSource="{Binding Facts}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0,1"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Padding="8,6" Margin="0,0,0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Content}"
                                           TextWrapping="Wrap" FontSize="12"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1" Text="{Binding ImportanceStars}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="#F0A000"/>

                                <TextBlock Grid.Column="2" Text="{Binding SubjectUid}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="3" Text="{Binding LastAccessed}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                <TextBlock Grid.Column="4" Text="{Binding Expires}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                <ui:Button Grid.Column="5" Content="✕" Padding="4,2"
                                           FontSize="11" Appearance="Secondary"
                                           VerticalAlignment="Center"
                                           Tag="{Binding Id}"
                                           Click="OnDeleteFactClicked"/>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Viewers list -->
        <Grid Grid.Row="1" x:Name="ViewersPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="4,0,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="昵称" Style="{StaticResource ColHeader}" Margin="4,0,0,0"/>
                <TextBlock Grid.Column="1" Text="UID" Style="{StaticResource ColHeader}"/>
                <TextBlock Grid.Column="2" Text="互动" Style="{StaticResource ColHeader}"/>
                <TextBlock Grid.Column="3" Text="平台" Style="{StaticResource ColHeader}"/>
                <TextBlock Grid.Column="4" Text="最后来访" Style="{StaticResource ColHeader}"/>
            </Grid>

            <ListBox Grid.Row="1" ItemsSource="{Binding Viewers}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0,1"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Padding="8,6" Margin="0,0,0,3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Nickname}"
                                           FontSize="12" FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="1" Text="{Binding Uid}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Column="2" Text="{Binding InteractionCount}"
                                           FontSize="12" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                <TextBlock Grid.Column="3" Text="{Binding Platform}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                <TextBlock Grid.Column="4" Text="{Binding LastSeen}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Status bar -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                   FontSize="11" Margin="0,6,0,0"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
    </Grid>
</UserControl>
