<Window x:Class="AIVTuber.App.Views.AvatarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AIVTuber Avatar"
        Width="480" Height="480"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="#00FF00"
        Topmost="True"
        ShowInTaskbar="True"
        AllowsTransparency="False">
    <Grid x:Name="RootGrid"
          ClipToBounds="False"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">
        <!-- Fixed pack-canvas inside Viewbox: body/head share the same pixel grid so neck_pivot maps 1:1. -->
        <Viewbox x:Name="AvatarViewbox"
                 Margin="0,28,0,0"
                 Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 SnapsToDevicePixels="True">
            <Grid x:Name="BodyLayer"
                  Width="1254" Height="1254"
                  RenderTransformOrigin="0.5,1"
                  SnapsToDevicePixels="True">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="BodyScale" ScaleX="1" ScaleY="1" />
                        <RotateTransform x:Name="BodyRotate" Angle="0" />
                        <TranslateTransform x:Name="BodyTranslate" X="0" Y="0" />
                    </TransformGroup>
                </Grid.RenderTransform>
                <Image x:Name="BodyImageB"
                       Width="1254" Height="1254"
                       Stretch="Fill"
                       Opacity="0"
                       IsHitTestVisible="False"
                       SnapsToDevicePixels="True" />
                <Image x:Name="BodyImageA"
                       Width="1254" Height="1254"
                       Stretch="Fill"
                       Opacity="1"
                       IsHitTestVisible="False"
                       SnapsToDevicePixels="True" />
                <!-- Head layer: rotate about neck_pivot in canvas pixels (CenterX/Y set in code). -->
                <Grid x:Name="HeadLayer"
                      Width="1254" Height="1254"
                      Visibility="Collapsed"
                      IsHitTestVisible="False"
                      SnapsToDevicePixels="True">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="HeadTilt" Angle="0" CenterX="627" CenterY="500" />
                            <TranslateTransform x:Name="HeadTranslate" X="0" Y="0" />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Image x:Name="HeadImageB"
                           Width="1254" Height="1254"
                           Stretch="Fill"
                           Opacity="0"
                           IsHitTestVisible="False"
                           SnapsToDevicePixels="True" />
                    <Image x:Name="HeadImageA"
                           Width="1254" Height="1254"
                           Stretch="Fill"
                           Opacity="1"
                           IsHitTestVisible="False"
                           SnapsToDevicePixels="True" />
                </Grid>
            </Grid>
        </Viewbox>

        <!-- Sticker overlay (canvas coords map to pack canvas, scaled to window) -->
        <Canvas x:Name="StickerCanvas" IsHitTestVisible="False">
            <Image x:Name="StickerImage"
                   Visibility="Collapsed"
                   Stretch="Uniform"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="StickerScale" ScaleX="1" ScaleY="1" />
                </Image.RenderTransform>
            </Image>
        </Canvas>

        <!-- Drag chrome / title strip (semi-transparent, top) -->
        <Border VerticalAlignment="Top" Height="28" Background="#33000000"
                MouseLeftButtonDown="OnChromeDrag"
                Cursor="SizeAll">
            <DockPanel Margin="8,0">
                <Button DockPanel.Dock="Right" Content="✕" Width="28" Height="22"
                        Click="OnCloseClick" Background="Transparent" BorderThickness="0"
                        Foreground="White" FontSize="12" Cursor="Hand"
                        ToolTip="关闭形象窗口（不影响主程序）" />
                <TextBlock x:Name="TitleText" Text="Avatar" VerticalAlignment="Center"
                           Foreground="White" FontSize="11" Opacity="0.85" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
