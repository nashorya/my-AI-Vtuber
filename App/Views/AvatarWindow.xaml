<Window x:Class="AIVTuber.App.Views.AvatarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AIVTuber Avatar"
        Width="480" Height="480"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="#00FF00"
        Topmost="True"
        ShowInTaskbar="True"
        AllowsTransparency="False">
    <Grid x:Name="RootGrid" ClipToBounds="True">
        <!-- Body cross-fade: previous (B) under current (A) -->
        <Grid x:Name="BodyLayer"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              RenderTransformOrigin="0.5,1">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="BodyScale" ScaleX="1" ScaleY="1" />
                    <RotateTransform x:Name="BodyRotate" Angle="0" />
                    <TranslateTransform x:Name="BodyTranslate" X="0" Y="0" />
                </TransformGroup>
            </Grid.RenderTransform>
            <Image x:Name="BodyImageB"
                   Stretch="Uniform"
                   Opacity="0"
                   IsHitTestVisible="False" />
            <Image x:Name="BodyImageA"
                   Stretch="Uniform"
                   Opacity="1"
                   IsHitTestVisible="False" />
        </Grid>

        <!-- Sticker overlay (canvas coords map to pack canvas, scaled to window) -->
        <Canvas x:Name="StickerCanvas" IsHitTestVisible="False">
            <Image x:Name="StickerImage"
                   Visibility="Collapsed"
                   Stretch="Uniform"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="StickerScale" ScaleX="1" ScaleY="1" />
                </Image.RenderTransform>
            </Image>
        </Canvas>

        <!-- Drag chrome / title strip (semi-transparent, top) -->
        <Border VerticalAlignment="Top" Height="28" Background="#33000000"
                MouseLeftButtonDown="OnChromeDrag"
                Cursor="SizeAll">
            <DockPanel Margin="8,0">
                <Button DockPanel.Dock="Right" Content="✕" Width="28" Height="22"
                        Click="OnCloseClick" Background="Transparent" BorderThickness="0"
                        Foreground="White" FontSize="12" Cursor="Hand"
                        ToolTip="关闭形象窗口（不影响主程序）" />
                <TextBlock x:Name="TitleText" Text="Avatar" VerticalAlignment="Center"
                           Foreground="White" FontSize="11" Opacity="0.85" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
