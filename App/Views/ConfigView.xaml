<UserControl x:Class="AIVTuber.App.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:AIVTuber.App.Views"
             xmlns:converters="clr-namespace:AIVTuber.App">
    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:KeySetStatusConverter x:Key="KeySetStatus" />
        <converters:KeySetBrushConverter x:Key="KeySetBrush" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
        <Style x:Key="FormTextBox" TargetType="ui:TextBox">
            <Setter Property="MinHeight" Value="{StaticResource ControlHeight}" />
        </Style>
    </UserControl.Resources>
    <UserControl.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{x:Static local:ConfigView.SaveCommand}" />
        <KeyBinding Key="Escape" Command="{x:Static local:ConfigView.DiscardCommand}" />
    </UserControl.InputBindings>

    <DockPanel Background="{DynamicResource AppSurfaceBrush}">
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource DeckPanelBrush}" Padding="12,8"
                BorderBrush="{DynamicResource DeckPanelBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <ui:Button x:Name="SaveButton" Grid.Column="0" Content="保存并应用" Icon="{ui:SymbolIcon Symbol=Save24}"
                           Appearance="Success" Click="OnSave" IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}" />
                <ui:Button Grid.Column="1" Content="放弃" Appearance="Transparent" Margin="8,0,0,0" Click="OnDiscard" />
                <StackPanel Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SaveStateText}" FontWeight="SemiBold" Foreground="{DynamicResource AppTextPrimaryBrush}" />
                    <TextBlock Text="{Binding Status}" Foreground="{DynamicResource AppTextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource AppDangerBrush}" FontSize="{StaticResource FontSizeCaption}"
                               Visibility="{Binding HasValidationErrors, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="SettingsSections" Margin="12" TabStripPlacement="Left">
            <TabItem Header="快速设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel MaxWidth="720">
                    <TextBlock Text="快速设置" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="输入设备" Style="{StaticResource FieldLabel}" />
                    <ComboBox ItemsSource="{Binding InputDevices}" SelectedIndex="{Binding Working.Audio.InputDeviceIndex}" MinHeight="{StaticResource ControlHeight}" />
                    <TextBlock Text="输入设备索引" Style="{StaticResource FieldLabel}" />
                    <ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Audio.InputDeviceIndex, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:ToggleSwitch Content="同时监听 PC 声音" IsChecked="{Binding Working.Audio.EnableLoopbackListen}" Margin="0,16,0,0" />
                    <ComboBox ItemsSource="{Binding LoopbackSources}" SelectedItem="{Binding SelectedLoopbackSource}" IsEnabled="{Binding Working.Audio.EnableLoopbackListen}" Margin="0,8,0,0" />
                    <ui:Button Content="刷新进程列表" Icon="{ui:SymbolIcon Symbol=ArrowSync24}" Click="OnRefreshLoopbackSources" IsEnabled="{Binding Working.Audio.EnableLoopbackListen}" Margin="0,8,0,0" />
                    <ui:ToggleSwitch Content="输出到虚拟麦克风" IsChecked="{Binding Working.Audio.EnableVirtualMic}" Margin="0,16,0,0" />
                    <ComboBox ItemsSource="{Binding OutputDevices}" SelectedItem="{Binding SelectedOutputDevice}" IsEnabled="{Binding Working.Audio.EnableVirtualMic}" Margin="0,8,0,0" />
                    <ui:Button Content="刷新输出设备" Icon="{ui:SymbolIcon Symbol=ArrowSync24}" Click="OnRefreshOutputDevices" IsEnabled="{Binding Working.Audio.EnableVirtualMic}" Margin="0,8,0,16" />
                </StackPanel></ScrollViewer>
            </TabItem>
            <TabItem Header="AI 引擎">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel MaxWidth="720">
                    <TextBlock Text="AI 引擎" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="LLM Base URL" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Llm.BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="LLM 模型" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Llm.Model, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="LLM API Key（留空不修改）" Style="{StaticResource FieldLabel}" /><ui:PasswordBox x:Name="LlmKey" />
                    <TextBlock Text="人设提示词" Style="{StaticResource FieldLabel}" /><ui:TextBox Text="{Binding Working.Llm.SystemPrompt, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="96" />
                    <TextBlock Text="ASR 提供商" Style="{StaticResource FieldLabel}" /><ComboBox SelectedValue="{Binding Working.Asr.Provider}" SelectedValuePath="Content"><ComboBoxItem Content="aliyun"/><ComboBoxItem Content="local"/></ComboBox>
                    <TextBlock Text="ASR API Key（local 可留空）" Style="{StaticResource FieldLabel}" /><ui:PasswordBox x:Name="AsrKey" />
                    <TextBlock Text="ASR 模型" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Asr.Model, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="本地 ASR 服务地址" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Asr.LocalAsrUrl, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="本地 ASR Python 路径" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Asr.PythonPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" />
                </StackPanel></ScrollViewer>
            </TabItem>
            <TabItem Header="语音">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel MaxWidth="720">
                    <TextBlock Text="语音" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="TTS 提供商" Style="{StaticResource FieldLabel}" /><ComboBox SelectedValue="{Binding Working.Tts.Provider}" SelectedValuePath="Content"><ComboBoxItem Content="fish-audio"/><ComboBoxItem Content="minimax"/><ComboBoxItem Content="aliyun"/></ComboBox>
                    <TextBlock Text="TTS API Key（留空不修改）" Style="{StaticResource FieldLabel}" /><ui:PasswordBox x:Name="TtsKey" />
                    <TextBlock Text="Voice ID" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Tts.VoiceId, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="模型" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Tts.Model, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="MiniMax Group ID" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Tts.GroupId, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="语速（0.5-2.0）" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Tts.Speed, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" />
                </StackPanel></ScrollViewer>
            </TabItem>
            <TabItem Header="直播集成">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel MaxWidth="720">
                    <TextBlock Text="直播集成" Style="{StaticResource SectionTitle}" />
                    <ui:ToggleSwitch Content="启用 OBS 字幕" IsChecked="{Binding Working.Obs.Enable}" />
                    <TextBlock Text="OBS 主机 / 端口" Style="{StaticResource FieldLabel}" /><StackPanel Orientation="Horizontal"><ui:TextBox Width="260" Text="{Binding Working.Obs.Host, UpdateSourceTrigger=PropertyChanged}"/><ui:TextBox Width="120" Margin="8,0,0,0" Text="{Binding Working.Obs.Port, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <TextBlock Text="OBS 密码（留空不修改）" Style="{StaticResource FieldLabel}" /><ui:PasswordBox x:Name="ObsPassword" />
                    <TextBlock Text="助手/用户文本组件" Style="{StaticResource FieldLabel}" /><StackPanel Orientation="Horizontal"><ui:TextBox Width="260" Text="{Binding Working.Obs.AssistantTextComponent, UpdateSourceTrigger=PropertyChanged}"/><ui:TextBox Width="260" Margin="8,0,0,0" Text="{Binding Working.Obs.UserTextComponent, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <TextBlock Text="字幕打字间隔（毫秒）" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Obs.TypewriterIntervalMs, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:ToggleSwitch Content="启用 B 站弹幕" IsChecked="{Binding Working.Bilibili.Enable}" Margin="0,16,0,0" />
                    <TextBlock Text="房间号 / 推送端口 / 选取间隔（秒）" Style="{StaticResource FieldLabel}" /><StackPanel Orientation="Horizontal"><ui:TextBox Width="150" Text="{Binding Working.Bilibili.RoomId, UpdateSourceTrigger=PropertyChanged}"/><ui:TextBox Width="150" Margin="8,0,0,0" Text="{Binding Working.Bilibili.PushPort, UpdateSourceTrigger=PropertyChanged}"/><ui:TextBox Width="150" Margin="8,0,0,0" Text="{Binding Working.Bilibili.SelectionIntervalSec, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <TextBlock Text="SESSDATA / bili_jct / buvid3（留空不修改）" Style="{StaticResource FieldLabel}" /><StackPanel><ui:PasswordBox x:Name="BiliSessdata"/><ui:PasswordBox x:Name="BiliJct" Margin="0,8,0,0"/><ui:PasswordBox x:Name="BiliBuvid3" Margin="0,8,0,0"/></StackPanel>
                    <TextBlock Text="B 站 Python 路径" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Bilibili.PythonPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" />
                </StackPanel></ScrollViewer>
            </TabItem>
            <TabItem Header="角色与动作">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel MaxWidth="760">
                    <TextBlock Text="角色与动作" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="VTS 主机 / 端口 / 嘴部幅度" Style="{StaticResource FieldLabel}" /><StackPanel Orientation="Horizontal"><ui:TextBox Width="220" Text="{Binding Working.Vts.Host, UpdateSourceTrigger=PropertyChanged}"/><ui:TextBox Width="120" Margin="8,0,0,0" Text="{Binding Working.Vts.Port, UpdateSourceTrigger=PropertyChanged}"/><ui:TextBox Width="120" Margin="8,0,0,0" Text="{Binding Working.Vts.MouthScale, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <ui:Button Content="查询现有热键" Icon="{ui:SymbolIcon Symbol=Search24}" Click="OnQueryVtsHotkeys" IsEnabled="{Binding IsQueryingHotkeys, Converter={StaticResource InverseBool}}" Margin="0,12,0,8" />
                    <TextBlock Text="仅编辑现有 VTS 热键映射；不提供预览、模型发现或连接管理。" Foreground="{DynamicResource AppTextSecondaryBrush}" TextWrapping="Wrap" />
                    <TextBlock Text="情绪映射" Style="{StaticResource FieldLabel}" />
                    <ItemsControl ItemsSource="{Binding EmotionRows}"><ItemsControl.ItemTemplate><DataTemplate><Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:TextBox Grid.Column="0" Text="{Binding Emotion, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="情绪别名"/><ui:TextBox Grid.Column="1" Margin="8,0" Text="{Binding HotkeyId, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="现有 VTS 热键 ID"/><ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Symbol=Delete24}" ToolTip="删除情绪映射" AutomationProperties.Name="删除情绪映射" Click="OnRemoveEmotionRow" Tag="{Binding}"/></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                    <ui:Button Content="添加情绪映射" Icon="{ui:SymbolIcon Symbol=Add24}" Click="OnAddEmotionRow" Margin="0,6,0,12" />
                    <TextBlock Text="动作映射" Style="{StaticResource FieldLabel}" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><ui:Button Content="导入动画热键" Icon="{ui:SymbolIcon Symbol=ArrowDownload24}" Click="OnImportAnimationHotkeys"/><ui:Button Content="添加动作映射" Icon="{ui:SymbolIcon Symbol=Add24}" Click="OnAddActionRow" Margin="8,0,0,0"/></StackPanel>
                    <ItemsControl ItemsSource="{Binding ActionRows}"><ItemsControl.ItemTemplate><DataTemplate><Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ui:TextBox Grid.Column="0" Text="{Binding Action, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="动作别名"/><ui:TextBox Grid.Column="1" Margin="8,0" Text="{Binding HotkeyId, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="现有 VTS 热键 ID"/><ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Symbol=Delete24}" ToolTip="删除动作映射" AutomationProperties.Name="删除动作映射" Click="OnRemoveActionRow" Tag="{Binding}"/></Grid></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                </StackPanel></ScrollViewer>
            </TabItem>
            <TabItem Header="高级">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel MaxWidth="720">
                    <TextBlock Text="高级" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="VAD 激进度（0-3）" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Audio.VadAggressiveness, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="前置/后置静音（毫秒）" Style="{StaticResource FieldLabel}" /><StackPanel Orientation="Horizontal"><ui:TextBox Width="180" Text="{Binding Working.Audio.PreSpeechPaddingMs, UpdateSourceTrigger=PropertyChanged}"/><ui:TextBox Width="180" Margin="8,0,0,0" Text="{Binding Working.Audio.PostSpeechSilenceMs, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    <TextBlock Text="最大历史 Token" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Llm.MaxHistoryTokens, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="记忆数据库 / 嵌入模型 / 提取轮数" Style="{StaticResource FieldLabel}" /><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Memory.DatabasePath, UpdateSourceTrigger=PropertyChanged}"/><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Memory.EmbeddingModelPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0"/><ui:TextBox Style="{StaticResource FormTextBox}" Text="{Binding Working.Memory.ExtractEveryNTurns, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0"/>
                    <TextBlock Text="麦克风/内录/弹幕输入模板" Style="{StaticResource FieldLabel}" /><ui:TextBox Text="{Binding Working.Input.MicTemplate, UpdateSourceTrigger=PropertyChanged}"/><ui:TextBox Text="{Binding Working.Input.LoopbackTemplate, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0"/><ui:TextBox Text="{Binding Working.Input.DanmakuTemplate, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,16"/>
                </StackPanel></ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
