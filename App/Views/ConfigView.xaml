<UserControl x:Class="AIVTuber.App.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:AIVTuber.App">
    <UserControl.Resources>
        <local:InverseBoolConverter x:Key="InverseBool" />
        <local:KeySetStatusConverter x:Key="KeySetStatus" />
        <local:KeySetBrushConverter x:Key="KeySetBrush" />
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="BadgeInstant" TargetType="Border">
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="Background" Value="#1A4CAF50" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="BadgeReconnect" TargetType="Border">
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="Background" Value="#1AE8A000" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="BadgeInstantText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#4CAF50" />
        </Style>
        <Style x:Key="BadgeReconnectText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="#E8A000" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="640" HorizontalAlignment="Left">

            <!-- ── LLM ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="LLM 大模型" Style="{StaticResource SectionHeader}" />
                <Border Style="{StaticResource BadgeInstant}">
                    <TextBlock Text="秒生效" Style="{StaticResource BadgeInstantText}" />
                </Border>
            </StackPanel>

            <TextBlock Text="Base URL" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Llm.BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="https://api.openai.com/v1"
                        Margin="0,0,0,10" />

            <TextBlock Text="Model" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Llm.Model, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="gpt-4o"
                        Margin="0,0,0,10" />

            <TextBlock Text="API Key（留空=不修改）" Style="{StaticResource FieldLabel}" />
            <ui:PasswordBox x:Name="LlmKey" PlaceholderText="sk-…" Margin="0,0,0,4" />
            <TextBlock Text="{Binding Working.Llm.ApiKey, Converter={StaticResource KeySetStatus}, Mode=OneWay}"
                       Foreground="{Binding Working.Llm.ApiKey, Converter={StaticResource KeySetBrush}, Mode=OneWay}"
                       FontSize="11" Margin="0,0,0,10" />

            <TextBlock Text="人设 system_prompt" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Llm.SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="True" MinHeight="72"
                        TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                        Margin="0,0,0,24" />

            <!-- ── Audio ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="音频" Style="{StaticResource SectionHeader}" />
                <Border Style="{StaticResource BadgeReconnect}">
                    <TextBlock Text="保存后重连" Style="{StaticResource BadgeReconnectText}" />
                </Border>
            </StackPanel>

            <TextBlock Text="输入设备" Style="{StaticResource FieldLabel}" />
            <ComboBox ItemsSource="{Binding InputDevices}"
                      SelectedIndex="{Binding Working.Audio.InputDeviceIndex}"
                      Margin="0,0,0,6" />
            <TextBlock Margin="0,0,0,4" FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InputDevices.Count}" Value="0">
                                <Setter Property="Text" Value="⚠ 未检测到录音设备 — 请检查 Windows 设置 › 隐私 › 麦克风权限，或手动填写索引↓" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="设备索引（手动填写，0=第一个设备）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Audio.InputDeviceIndex, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,10" />

            <ui:ToggleSwitch Content="同时监听 PC 声音（PK / 连麦）"
                             IsChecked="{Binding Working.Audio.EnableLoopbackListen}"
                             Margin="0,0,0,8" />

            <TextBlock Text="监听来源（仅在开启时生效）" Style="{StaticResource FieldLabel}" />
            <ComboBox ItemsSource="{Binding LoopbackSources}"
                      SelectedItem="{Binding SelectedLoopbackSource}"
                      IsEnabled="{Binding Working.Audio.EnableLoopbackListen}"
                      Margin="0,0,0,4" />
            <ui:Button Content="刷新进程列表"
                       Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                       Click="OnRefreshLoopbackSources"
                       IsEnabled="{Binding Working.Audio.EnableLoopbackListen}"
                       Margin="0,0,0,4" />
            <TextBlock FontSize="11" Margin="0,0,0,24"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Text="麦克风优先级更高。选「全部音源」捕获扬声器混音；选具体进程则只录该进程（Win11 免虚拟声卡）" />

            <!-- ── TTS ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="TTS 语音合成" Style="{StaticResource SectionHeader}" />
                <Border Style="{StaticResource BadgeInstant}">
                    <TextBlock Text="秒生效" Style="{StaticResource BadgeInstantText}" />
                </Border>
            </StackPanel>

            <TextBlock Text="Provider（fish-audio / minimax / aliyun）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Tts.Provider, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="fish-audio"
                        Margin="0,0,0,10" />

            <TextBlock Text="API Key（留空=不修改）" Style="{StaticResource FieldLabel}" />
            <ui:PasswordBox x:Name="TtsKey" PlaceholderText="…" Margin="0,0,0,4" />
            <TextBlock Text="{Binding Working.Tts.ApiKey, Converter={StaticResource KeySetStatus}, Mode=OneWay}"
                       Foreground="{Binding Working.Tts.ApiKey, Converter={StaticResource KeySetBrush}, Mode=OneWay}"
                       FontSize="11" Margin="0,0,0,10" />

            <TextBlock Text="Voice ID（fish: reference_id；aliyun: 音色名如 longanyang）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Tts.VoiceId, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,10" />

            <TextBlock Text="Model（留空=默认：fish s1 / minimax speech-2.8-hd / aliyun cosyvoice-v3-flash）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Tts.Model, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,10" />

            <TextBlock Text="GroupId（MiniMax 旧平台，新平台已废弃可留空）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Tts.GroupId, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,10" />

            <TextBlock Text="语速 Speed（0.5–2.0）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Tts.Speed, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,24" />

            <!-- ── ASR ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="ASR 语音识别" Style="{StaticResource SectionHeader}" />
                <Border Style="{StaticResource BadgeInstant}">
                    <TextBlock Text="秒生效" Style="{StaticResource BadgeInstantText}" />
                </Border>
            </StackPanel>

            <TextBlock Text="Provider（aliyun = DashScope 云端识别 / local = 本地服务）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Asr.Provider, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="aliyun"
                        Margin="0,0,0,10" />

            <TextBlock Text="API Key（留空=不修改，Provider=local 时可留空）" Style="{StaticResource FieldLabel}" />
            <ui:PasswordBox x:Name="AsrKey" PlaceholderText="…" Margin="0,0,0,4" />
            <TextBlock Text="{Binding Working.Asr.ApiKey, Converter={StaticResource KeySetStatus}, Mode=OneWay}"
                       Foreground="{Binding Working.Asr.ApiKey, Converter={StaticResource KeySetBrush}, Mode=OneWay}"
                       FontSize="11" Margin="0,0,0,10" />

            <TextBlock Text="Model（留空=默认：aliyun paraformer-realtime-v2；local 忽略此项）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Asr.Model, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,10" />

            <TextBlock Text="本地 ASR 服务地址（Provider=local 时生效）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Asr.LocalAsrUrl, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="http://localhost:8765"
                        Margin="0,0,0,10" />

            <TextBlock Text="Python 路径（本地 ASR 服务用，留空=python）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Asr.PythonPath, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="python"
                        Margin="0,0,0,4" />
            <TextBlock Text="保存后 app 会自动在后台启动 asr_server.py，状态栏显示 ● 本地ASR"
                       FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="0,0,0,24" />

            <!-- ── VTS ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="VTS" Style="{StaticResource SectionHeader}" />
                <Border Style="{StaticResource BadgeReconnect}">
                    <TextBlock Text="连接变更需重连" Style="{StaticResource BadgeReconnectText}" />
                </Border>
            </StackPanel>

            <TextBlock Text="Host" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Vts.Host, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="localhost"
                        Margin="0,0,0,10" />

            <TextBlock Text="Port" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Vts.Port, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="8001"
                        Margin="0,0,0,10" />

            <TextBlock Text="嘴部张合幅度（MouthScale，看起来幅度太小就调大，如 5）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Vts.MouthScale, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,0,10" />

            <ui:Button Content="查询热键列表"
                       Icon="{ui:SymbolIcon Symbol=Search24}"
                       Click="OnQueryVtsHotkeys"
                       IsEnabled="{Binding IsQueryingHotkeys, Converter={StaticResource InverseBool}}"
                       Margin="0,0,0,6" />
            <ItemsControl ItemsSource="{Binding HotkeyList}" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontFamily="Consolas" FontSize="11" Margin="0,2">
                            <Run Text="{Binding HotkeyId, Mode=OneWay}"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <Run Text="  " />
                            <Run Text="{Binding HotkeyName, Mode=OneWay}" />
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="情绪 → 热键映射" Style="{StaticResource FieldLabel}" />
            <TextBlock Text="LLM 会在合适时机自己插入 [emotion:词] 来触发对应的 VTS 热键；下面配的“情绪词”就会自动写入系统提示词，不用手改提示词或 config.json。"
                       FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="0,0,0,8" />
            <ItemsControl ItemsSource="{Binding EmotionRows}" Margin="0,0,0,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0" Text="{Binding Emotion, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="情绪词，如 happy" Margin="0,0,6,0" />
                            <ComboBox Grid.Column="1" Margin="0,0,6,0"
                                      ItemsSource="{Binding DataContext.HotkeyList, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedValuePath="HotkeyId"
                                      SelectedValue="{Binding HotkeyId, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Symbol=Delete24}"
                                       Click="OnRemoveEmotionRow" Tag="{Binding}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ui:Button Content="添加映射" Icon="{ui:SymbolIcon Symbol=Add24}" Click="OnAddEmotionRow" Margin="0,0,0,24" />

            <!-- ── Input Templates ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="输入格式模板" Style="{StaticResource SectionHeader}" />
                <Border Style="{StaticResource BadgeInstant}">
                    <TextBlock Text="秒生效" Style="{StaticResource BadgeInstantText}" />
                </Border>
            </StackPanel>

            <TextBlock Text="麦克风（用 {text} 代表识别内容）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Input.MicTemplate, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="（你的创造者对你说：{text}）"
                        Margin="0,0,0,10" />

            <TextBlock Text="内录 / 对面主播（用 {text} 代表识别内容）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Input.LoopbackTemplate, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="（你听到对面说：{text}）"
                        Margin="0,0,0,10" />

            <TextBlock Text="弹幕（用 {username} 代表用户名，{content} 代表弹幕内容）" Style="{StaticResource FieldLabel}" />
            <ui:TextBox Text="{Binding Working.Input.DanmakuTemplate, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="（弹幕 {username}：{content}）"
                        Margin="0,0,0,24" />

            <!-- ── OBS / Bilibili ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="OBS / B站" Style="{StaticResource SectionHeader}" />
                <Border Style="{StaticResource BadgeReconnect}">
                    <TextBlock Text="开关与连接需重连" Style="{StaticResource BadgeReconnectText}" />
                </Border>
            </StackPanel>

            <ui:ToggleSwitch Content="启用 OBS 字幕" IsChecked="{Binding Working.Obs.Enable}" Margin="0,0,0,8" />
            <ui:ToggleSwitch Content="启用 B站弹幕" IsChecked="{Binding Working.Bilibili.Enable}" Margin="0,0,0,24" />

            <!-- ── Placeholder: Tools ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12" Opacity="0.45">
                <TextBlock Text="工具 / 联网搜索" Style="{StaticResource SectionHeader}" />
                <Border CornerRadius="5" Padding="7,2" Margin="10,0,0,0"
                        Background="#22888888" VerticalAlignment="Center">
                    <TextBlock Text="即将支持" FontSize="10" Foreground="#888" />
                </Border>
            </StackPanel>
            <ui:ToggleSwitch Content="启用联网搜索" IsEnabled="False" Margin="0,0,0,28" Opacity="0.45" />

            <!-- ── Save ── -->
            <ui:Card Padding="16,12">
                <DockPanel>
                    <ui:Button x:Name="SaveButton"
                               Content="保存并应用"
                               Icon="{ui:SymbolIcon Symbol=Save24}"
                               Appearance="Primary"
                               Click="OnSave"
                               DockPanel.Dock="Left" />
                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                               Margin="16,0,0,0" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </DockPanel>
            </ui:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
