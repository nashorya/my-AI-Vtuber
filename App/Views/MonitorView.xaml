<UserControl x:Class="AIVTuber.App.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:AIVTuber.App">
    <UserControl.Resources>
        <local:PipelineStateToLabelConverter x:Key="StateLabel" />
        <local:BoolToGreenGrayBrushConverter x:Key="ConnBrush" />
        <local:BoolToAvailabilityTextConverter x:Key="AvailabilityText" />
        <local:OperationalEventForegroundConverter x:Key="OperationalEventForeground" />
    </UserControl.Resources>

    <Grid Margin="12" Background="{DynamicResource AppSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Fixed command strip: controls remain in reserved slots in every state. -->
        <Border Grid.Row="0" Padding="12,8" Margin="0,0,0,8"
                Background="{DynamicResource DeckPanelBrush}" BorderBrush="{DynamicResource DeckPanelBorderBrush}"
                BorderThickness="3,1,1,1" CornerRadius="{StaticResource CornerRadiusDeck}">
            <Grid MinHeight="{StaticResource CommandBarHeight}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="LIVE CONTROL" FontSize="{StaticResource FontSizeBody}" FontWeight="Bold"
                               Foreground="{DynamicResource DeckAccentBrush}" Margin="0,0,16,0" />
                    <TextBlock Text="{Binding State, Converter={StaticResource StateLabel}}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="  |  " Foreground="{DynamicResource AppTextSecondaryBrush}" />
                    <TextBlock Text="VTS " Foreground="{DynamicResource AppTextSecondaryBrush}" />
                    <TextBlock Text="{Binding VtsConnected, Converter={StaticResource AvailabilityText}}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                    <TextBlock Text="  OBS " Foreground="{DynamicResource AppTextSecondaryBrush}" />
                    <TextBlock Text="{Binding ObsConnected, Converter={StaticResource AvailabilityText}}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                    <TextBlock Text="  弹幕 " Foreground="{DynamicResource AppTextSecondaryBrush}" />
                    <TextBlock Text="{Binding DanmakuActive, Converter={StaticResource AvailabilityText}}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                </WrapPanel>
                <ui:Button Grid.Column="1" x:Name="StopSpeakingButton" Content="截停"
                           Icon="{ui:SymbolIcon Symbol=Dismiss24}" Width="88" Height="{StaticResource DeckToolHeight}" Margin="8,0,0,0"
                           Appearance="Danger" IsEnabled="{Binding CanStop}" Click="OnStopSpeakingClicked"
                           ToolTip="停止当前生成或语音" AutomationProperties.Name="截停说话" />
                <ui:Button Grid.Column="2" x:Name="MicMuteButton" Width="96" Height="{StaticResource DeckToolHeight}"
                           Margin="8,0,0,0" Click="OnMicMuteClicked" ToolTip="切换麦克风静音"
                           AutomationProperties.Name="切换麦克风静音">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Content" Value="麦克风" />
                            <Setter Property="Appearance" Value="Dark" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MicMuted}" Value="True">
                                    <Setter Property="Content" Value="静音中" />
                                    <Setter Property="Appearance" Value="Danger" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      SizeChanged="OnContentViewportSizeChanged">
            <WrapPanel x:Name="MonitorPanels">
                <Border Width="620" MinHeight="360" Padding="12" Margin="0,0,8,8"
                        Background="{DynamicResource DeckPanelBrush}" BorderBrush="{DynamicResource DeckPanelBorderBrush}"
                        BorderThickness="{StaticResource DeckPanelBorderThickness}" CornerRadius="{StaticResource CornerRadiusPanel}">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="EVENT LOG" FontWeight="Bold" FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource DeckAccentBrush}" />
                                <TextBlock Text="最多保留 500 条 · 最新在顶部" FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            </StackPanel>
                            <ui:Button Grid.Column="1" Content="最新" Appearance="Transparent" Height="{StaticResource DeckToolHeight}"
                                       Click="OnReturnToLatest" ToolTip="恢复跟随最新事件" AutomationProperties.Name="回到最新事件" />
                        </Grid>
                        <ScrollViewer x:Name="OperationalEventScrollViewer" MaxHeight="360" VerticalScrollBarVisibility="Auto"
                                      ScrollChanged="OnOperationalEventScrollChanged">
                            <ItemsControl ItemsSource="{Binding OperationalEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource AppSurfaceRaisedBrush}" BorderThickness="0,0,0,1" Padding="0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="72" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" FontSize="{StaticResource FontSizeCaption}"
                                                           Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,12,0" />
                                                <TextBlock Grid.Column="1" Text="{Binding Source}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                                <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap"
                                                           Foreground="{Binding IsError, Converter={StaticResource OperationalEventForeground}}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <StackPanel Width="300">
                    <Border Padding="12" Margin="0,0,0,8" Background="{DynamicResource DeckPanelBrush}"
                            BorderBrush="{DynamicResource DeckPanelBorderBrush}" BorderThickness="{StaticResource DeckPanelBorderThickness}"
                            CornerRadius="{StaticResource CornerRadiusPanel}">
                        <StackPanel>
                            <TextBlock Text="CURRENT INPUT" FontWeight="Bold" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource DeckAccentBrush}" />
                            <TextBlock Text="用户输入" Margin="0,12,0,2" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="{Binding UserText, TargetNullValue=（等待输入）}" TextWrapping="Wrap" Foreground="{DynamicResource AppTextPrimaryBrush}" />
                                    <TextBlock Text="AI 回复" Margin="0,12,0,2" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                    <TextBlock Text="{Binding AssistantText, TargetNullValue=（等待回复）}" TextWrapping="Wrap" Foreground="{DynamicResource AppTextPrimaryBrush}" />
                                    <TextBlock Text="内录" Margin="0,12,0,2" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                    <TextBlock Text="{Binding OpponentText, TargetNullValue=（无）}" TextWrapping="Wrap" Foreground="{DynamicResource AppTextPrimaryBrush}" />
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                    <Border Padding="12" Margin="0,0,0,8" Background="{DynamicResource DeckPanelBrush}"
                            BorderBrush="{DynamicResource DeckPanelBorderBrush}" BorderThickness="{StaticResource DeckPanelBorderThickness}"
                            CornerRadius="{StaticResource CornerRadiusPanel}">
                        <StackPanel>
                            <TextBlock Text="CHAT QUEUE" FontWeight="Bold" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource DeckAccentBrush}" />
                            <TextBlock Text="{Binding DanmakuQueueCount, StringFormat=当前 {0} 条}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,4,0,8" />
                            <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DanmakuQueue}">
                                    <ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,3" Foreground="{DynamicResource AppTextPrimaryBrush}" /></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Manual PNG-avatar probes (backend=pixel|both). Safe no-ops when off. -->
                    <Border Padding="12" Background="{DynamicResource DeckPanelBrush}"
                            BorderBrush="{DynamicResource DeckPanelBorderBrush}" BorderThickness="{StaticResource DeckPanelBorderThickness}"
                            CornerRadius="{StaticResource CornerRadiusPanel}">
                        <StackPanel>
                            <TextBlock Text="AVATAR TEST" FontWeight="Bold" FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource DeckAccentBrush}" />
                            <TextBlock Text="表情 / 贴纸 / 口型 · 需 avatar.backend=pixel|both"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,8" />
                            <TextBlock Text="表情" FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4" />
                            <WrapPanel>
                                <ui:Button Content="开心" Appearance="Secondary" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarEmotion" Tag="happy"
                                           ToolTip="SetEmotion(happy)" AutomationProperties.Name="测表情开心" />
                                <ui:Button Content="害羞" Appearance="Secondary" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarEmotion" Tag="shy"
                                           ToolTip="SetEmotion(shy)" AutomationProperties.Name="测表情害羞" />
                                <ui:Button Content="生气" Appearance="Secondary" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarEmotion" Tag="angry"
                                           ToolTip="SetEmotion(angry) + shake" AutomationProperties.Name="测表情生气" />
                                <ui:Button Content="无语" Appearance="Secondary" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarEmotion" Tag="upset"
                                           ToolTip="SetEmotion(upset)" AutomationProperties.Name="测表情无语" />
                                <ui:Button Content="惊讶" Appearance="Secondary" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarEmotion" Tag="surprised"
                                           ToolTip="SetEmotion(surprised) + jump" AutomationProperties.Name="测表情惊讶" />
                                <ui:Button Content="难过" Appearance="Secondary" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarEmotion" Tag="sad"
                                           ToolTip="SetEmotion(sad) + sink" AutomationProperties.Name="测表情难过" />
                            </WrapPanel>
                            <TextBlock Text="倾听" FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,4,0,4" />
                            <WrapPanel>
                                <ui:Button x:Name="AvatarListeningButton" Content="倾听 ON" Appearance="Secondary"
                                           Height="32" Margin="0,0,6,6" Padding="10,0"
                                           Click="OnAvatarListening" Tag="listening"
                                           ToolTip="SetListening(true) — 头部歪 + 眨眼变勤"
                                           AutomationProperties.Name="测倾听姿态" />
                            </WrapPanel>
                            <TextBlock Text="挂机 / 贴纸" FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,4,0,4" />
                            <WrapPanel>
                                <ui:Button Content="睡觉" Appearance="Secondary" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarIdle" Tag="sleep"
                                           ToolTip="SetIdleState(sleep)" AutomationProperties.Name="测挂机睡觉" />
                                <ui:Button Content="醒着" Appearance="Secondary" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarIdle" Tag="neutral"
                                           ToolTip="清除挂机状态" AutomationProperties.Name="清除挂机" />
                                <ui:Button Content="流汗黄豆" Appearance="Primary" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarSticker" Tag="sweat_laugh"
                                           ToolTip="ShowSticker(sweat_laugh)" AutomationProperties.Name="测贴纸流汗" />
                            </WrapPanel>
                            <TextBlock Text="口型 (合成 RMS)" FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,4,0,4" />
                            <WrapPanel>
                                <ui:Button Content="闭嘴" Appearance="Transparent" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarRms" Tag="0"
                                           ToolTip="OnRms(0)" AutomationProperties.Name="测口型闭嘴" />
                                <ui:Button Content="半开" Appearance="Transparent" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarRms" Tag="0.2"
                                           ToolTip="OnRms(0.2) → mouth_half" AutomationProperties.Name="测口型半开" />
                                <ui:Button Content="大开" Appearance="Transparent" Height="32" Margin="0,0,6,6"
                                           Padding="10,0" Click="OnAvatarRms" Tag="0.6"
                                           ToolTip="OnRms(0.6) → mouth_open" AutomationProperties.Name="测口型大开" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </WrapPanel>
        </ScrollViewer>

        <WrapPanel Grid.Row="2" Margin="0,8,0,0">
            <TextBlock Text="ASR " Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <TextBlock Text="{Binding AsrLatencyMs, TargetNullValue=—}" Foreground="{DynamicResource AppTextPrimaryBrush}" />
            <TextBlock Text=" ms    LLM " Margin="12,0,0,0" Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <TextBlock Text="{Binding LlmLatencyMs, TargetNullValue=—}" Foreground="{DynamicResource AppTextPrimaryBrush}" />
            <TextBlock Text=" ms    TTS " Margin="12,0,0,0" Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <TextBlock Text="{Binding TtsLatencyMs, TargetNullValue=—}" Foreground="{DynamicResource AppTextPrimaryBrush}" />
            <TextBlock Text=" ms" Foreground="{DynamicResource AppTextSecondaryBrush}" />
        </WrapPanel>
    </Grid>
</UserControl>
