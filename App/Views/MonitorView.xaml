<UserControl x:Class="AIVTuber.App.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:AIVTuber.App">
    <UserControl.Resources>
        <local:PipelineStateToLabelConverter x:Key="StateLabel" />
        <local:BoolToGreenGrayBrushConverter x:Key="ConnBrush" />
        <local:MicLevelToWidthConverter x:Key="MicLevelWidth" />
    </UserControl.Resources>

    <Grid Margin="16,12,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Status bar ── -->
        <ui:Card Grid.Row="0" Margin="0,0,0,12" Padding="12,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Pipeline state badge -->
                <Border CornerRadius="10" Padding="10,4" Margin="0,0,20,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#44444488" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State}" Value="Listening">
                                    <Setter Property="Background" Value="#221A6AB4" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="Thinking">
                                    <Setter Property="Background" Value="#22C97600" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding State}" Value="Speaking">
                                    <Setter Property="Background" Value="#224CAF50" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#666" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State}" Value="Listening">
                                            <Setter Property="Fill" Value="#4A90D9" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State}" Value="Thinking">
                                            <Setter Property="Fill" Value="#E8A000" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State}" Value="Speaking">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding State, Converter={StaticResource StateLabel}}"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontWeight="SemiBold" FontSize="13" />
                    </StackPanel>
                </Border>

                <!-- Connection indicators -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center"
                             Fill="{Binding VtsConnected, Converter={StaticResource ConnBrush}}" />
                    <TextBlock Text="VTS" FontSize="12" Margin="0,0,16,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center"
                             Fill="{Binding ObsConnected, Converter={StaticResource ConnBrush}}" />
                    <TextBlock Text="OBS" FontSize="12" Margin="0,0,16,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center"
                             Fill="{Binding DanmakuActive, Converter={StaticResource ConnBrush}}" />
                    <TextBlock Text="弹幕" FontSize="12" Margin="0,0,16,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <!-- Local ASR indicator + restart button: only shown when provider=local -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LocalAsrActive}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Ellipse Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center"
                                 Fill="{Binding LocalAsrReachable, Converter={StaticResource ConnBrush}}" />
                        <TextBlock Text="本地ASR" FontSize="12" Margin="0,0,6,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:Button x:Name="RestartAsrButton"
                                   Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                                   Appearance="Secondary"
                                   Height="22" Padding="6,0"
                                   FontSize="11"
                                   Click="OnRestartLocalAsr"
                                   ToolTip="重启本地ASR服务" />
                    </StackPanel>

                    <!-- Loopback level bar -->
                    <TextBlock Text="内录" FontSize="12" Margin="0,0,5,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Border Width="60" Height="6" CornerRadius="3"
                            Background="#33FFFFFF" VerticalAlignment="Center">
                        <Border CornerRadius="3" HorizontalAlignment="Left" Background="#9C27B0"
                                Width="{Binding LoopbackLevel, Converter={StaticResource MicLevelWidth}}" />
                    </Border>
                </StackPanel>

                <!-- Mic level bar -->
                <Border Margin="16,0,6,0" Width="60" Height="6" CornerRadius="3"
                        Background="#33FFFFFF" VerticalAlignment="Center">
                    <Border x:Name="MicLevelFill" CornerRadius="3" HorizontalAlignment="Left"
                            Width="{Binding MicLevel, Converter={StaticResource MicLevelWidth}}"
                            Background="#4CAF50">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#4CAF50"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MicMuted}" Value="True">
                                        <Setter Property="Background" Value="#555"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Border>

                <!-- Stop speaking (interrupt) — only shown while the AI is thinking/speaking,
                     so it never pushes the mic-mute button off the toolbar when idle. -->
                <ui:Button x:Name="StopSpeakingButton"
                           Content="截停说话"
                           Margin="0,0,8,0" Padding="10,4"
                           FontSize="12"
                           Click="OnStopSpeakingClicked">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Setter Property="Appearance" Value="Danger" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanStop}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>

                <!-- Mic mute toggle -->
                <ui:Button x:Name="MicMuteButton"
                           Margin="0,0,0,0" Padding="10,4"
                           FontSize="12" Click="OnMicMuteClicked">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Content" Value="麦克风 开" />
                            <Setter Property="Appearance" Value="Secondary" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding MicMuted}" Value="True">
                                    <Setter Property="Content" Value="麦克风 关" />
                                    <Setter Property="Appearance" Value="Danger" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </StackPanel>
        </ui:Card>

        <!-- ── Main content ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- Chat card -->
            <ui:Card Grid.Column="0" Margin="0,0,12,0" Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="实时对话"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,14"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <StackPanel>
                        <!-- Error banner — only visible when LastError is non-empty -->
                        <Border CornerRadius="6" Padding="10,7" Margin="0,0,0,14"
                                Background="#22E53935">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LastError}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding LastError}"
                                       TextWrapping="Wrap" FontSize="12" FontFamily="Consolas"
                                       Foreground="#E53935" />
                        </Border>

                        <TextBlock Text="用户" FontSize="11" Margin="0,0,0,5"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <TextBlock Text="{Binding UserText, TargetNullValue='（等待输入）'}"
                                   TextWrapping="Wrap" FontSize="14" Margin="0,0,0,20"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="AI" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"
                                   Foreground="#4CAF50" />
                        <TextBlock Text="{Binding AssistantText, TargetNullValue='（等待回复）'}"
                                   TextWrapping="Wrap" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                        <!-- Opponent (loopback) transcript — hidden when empty -->
                        <Border Margin="0,16,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OpponentText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="对面" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"
                                           Foreground="#9C27B0" />
                                <TextBlock Text="{Binding OpponentText}"
                                           TextWrapping="Wrap" FontSize="14"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </ui:Card>

            <!-- Right panel -->
            <StackPanel Grid.Column="1">

                <!-- Emotion card -->
                <ui:Card Padding="16" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="情绪" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="AI" FontSize="10" Margin="0,0,0,4"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock Text="{Binding Emotion, TargetNullValue='—'}"
                                           FontSize="18" FontWeight="Light"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="用户" FontSize="10" Margin="0,0,0,4"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                <TextBlock Text="{Binding UserEmotion, TargetNullValue='—'}"
                                           FontSize="18" FontWeight="Light"
                                           Foreground="#5B9BD5" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Danmaku queue card -->
                <ui:Card Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="弹幕队列" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text=" · " FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="{Binding DanmakuQueueCount}" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding DanmakuQueue}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Username}"
                                                   FontSize="11" Margin="0,0,7,0"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Content}"
                                                   FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </Grid>

        <!-- ── Latency footer ── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <ui:SymbolIcon Symbol="Timer24" FontSize="13" Margin="0,0,5,0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                <Run Text="ASR" />
                <Run Text=" " />
                <Run Text="{Binding AsrLatencyMs, TargetNullValue='—', Mode=OneWay}" />
                <Run Text=" ms" />
            </TextBlock>
            <TextBlock Margin="20,0,0,0" FontSize="12"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                <Run Text="LLM" />
                <Run Text=" " />
                <Run Text="{Binding LlmLatencyMs, TargetNullValue='—', Mode=OneWay}" />
                <Run Text=" ms" />
            </TextBlock>
            <TextBlock Margin="20,0,0,0" FontSize="12"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                <Run Text="TTS" />
                <Run Text=" " />
                <Run Text="{Binding TtsLatencyMs, TargetNullValue='—', Mode=OneWay}" />
                <Run Text=" ms" />
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
