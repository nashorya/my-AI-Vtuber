{
  "audio": {
    "input_device_index": 0,
    "output_device_index": -1,
    "use_loopback": false,
    "loopback_device_name": "",
    "enable_loopback_listen": false,
    "loopback_process_name": "",
    "enable_virtual_mic": false,
    "virtual_mic_device_name": "",
    "vad_aggressiveness": 2,
    "pre_speech_padding_ms": 200,
    "post_speech_silence_ms": 500
  },
  "asr": {
    "provider": "aliyun",
    "api_key": "<your-asr-api-key>",
    "app_id": "<your-asr-app-id>",
    "model": "",
    "local_asr_url": "http://localhost:8765",
    "python_path": "sidecar/python/python.exe",
    "persist_connection": true,
    "streaming": true
  },
  "llm": {
    "base_url": "https://api.deepseek.com",
    "api_key": "<your-llm-api-key>",
    "model": "deepseek-chat",
    "system_prompt": "你是一个VTuber...",
    "max_history_tokens": 4096
  },
  "tts": {
    "provider": "fish-audio",
    "api_key": "<your-tts-api-key>",
    "voice_id": "<your-voice-id>",
    "model": "",
    "group_id": "",
    "speed": 1
  },
  "vts": {
    "host": "localhost",
    "port": 8001,
    "mouth_scale": 1.5,
    "emotion_map": {
      "happy": "<hotkey_id>",
      "sad": "<hotkey_id>",
      "angry": "<hotkey_id>",
      "surprised": "<hotkey_id>"
    },
    "action_map": {
      "head_shake": "<trigger-animation-hotkey-id>",
      "head_nod": "<trigger-animation-hotkey-id>"
    }
  },
  "obs": {
    "enable": false,
    "host": "localhost",
    "port": 4455,
    "password": "",
    "assistant_text_component": "AssistantText",
    "user_text_component": "UserText",
    "typewriter_interval_ms": 50
  },
  "memory": {
    "database_path": "memory.db",
    "extract_every_n_turns": 5,
    "embedding_model_path": "models/bge-small-zh"
  },
  "bilibili": {
    "enable": false,
    "room_id": 0,
    "sessdata": "<your-sessdata>",
    "bili_jct": "<your-bili-jct>",
    "buvid3": "<your-buvid3>",
    "push_port": 19876,
    "selection_interval_sec": 8,
    "python_path": "python"
  },
  "input": {
    "mic_template": "（你的创造者对你说：{text}）",
    "loopback_template": "（你听到对面说：{text}）",
    "danmaku_template": "（弹幕 {username}：{content}）"
  },
  "avatar": {
    "backend": "vts",
    "assets_path": "assets/avatar",
    "topmost": true,
    "background_color": "#00FF00",
    "allows_transparency": false,
    "window_width": 480,
    "window_height": 480,
    "scaling_mode": "auto",
    "snap_motion_to_pixels": false,
    "emotion_map": {
      "happy": "happy",
      "开心": "happy",
      "shy": "shy",
      "害羞": "shy",
      "angry": "angry",
      "生气": "angry",
      "upset": "upset",
      "无语": "upset",
      "surprised": "surprised",
      "惊讶": "surprised",
      "sad": "sad",
      "难过": "sad",
      "sleep": "sleep",
      "困": "sleep"
    }
  }
}
