{
  "meta": {
    "name": "鲸鱼女仆 v0.6",
    "canvas": {
      "width": 1254,
      "height": 1254
    },
    "pivot": {
      "x": 627,
      "y": 1180,
      "comment": "脚底中心,旋转/缩放锚点"
    },
    "note": "文件名保持gen_XX不改,状态映射只在本文件维护。带 _verify:true 的状态表示表情标注待人工确认,对照 contact_sheet.png(顺序gen_00~11,每行4张)核对,标错了改这里的file字段即可。"
  },
  "states": {
    "neutral": {
      "file": "sprites/gen_00.png",
      "category": "base",
      "transition": {
        "type": "cut"
      }
    },
    "blink": {
      "file": "sprites/gen_03.png",
      "category": "base",
      "transition": {
        "type": "cut"
      },
      "auto": {
        "interval_ms": [
          2000,
          6000
        ],
        "duration_ms": 120,
        "double_blink_chance": 0.15
      }
    },
    "mouth_half": {
      "file": "sprites/gen_01.png",
      "category": "mouth",
      "transition": {
        "type": "cut"
      },
      "_verify": true
    },
    "mouth_open": {
      "file": "sprites/gen_02.png",
      "category": "mouth",
      "transition": {
        "type": "cut"
      },
      "_verify": true
    },
    "happy": {
      "file": "sprites/gen_04.png",
      "category": "emotion",
      "transition": {
        "type": "cut"
      },
      "_verify": true,
      "motion_override": {
        "bounce_scale": 1.6
      }
    },
    "shy": {
      "file": "sprites/gen_05.png",
      "category": "emotion",
      "transition": {
        "type": "fade",
        "ms": 150
      },
      "_verify": true
    },
    "angry": {
      "file": "sprites/gen_06.png",
      "category": "emotion",
      "transition": {
        "type": "cut"
      },
      "motion_override": {
        "shake": {
          "amp_px": 6,
          "freq_hz": 9,
          "duration_ms": 600
        }
      }
    },
    "upset": {
      "file": "sprites/gen_07.png",
      "category": "emotion",
      "transition": {
        "type": "fade",
        "ms": 150
      },
      "_verify": true
    },
    "surprised": {
      "file": "sprites/gen_08.png",
      "category": "emotion",
      "transition": {
        "type": "cut"
      },
      "_verify": true,
      "motion_override": {
        "jump_px": 18
      }
    },
    "sad": {
      "file": "sprites/gen_09.png",
      "category": "emotion",
      "transition": {
        "type": "fade",
        "ms": 200
      },
      "_verify": true,
      "motion_override": {
        "breath_rate_scale": 0.6,
        "sink_px": 8
      }
    },
    "sleep": {
      "file": "sprites/gen_11.png",
      "category": "special",
      "transition": {
        "type": "fade",
        "ms": 450
      },
      "comment": "挂机专属,全身姿势不同,必须fade"
    }
  },
  "mouth_sync": {
    "comment": "RMS三档口型,数值为归一化音量阈值,情绪期间锁定当前脸不切嘴",
    "levels": [
      {
        "below": 0.06,
        "state": "neutral"
      },
      {
        "below": 0.35,
        "state": "mouth_half"
      },
      {
        "below": 1.01,
        "state": "mouth_open"
      }
    ],
    "hold_ms": 60
  },
  "motion_layer": {
    "breath": {
      "scale_amp": 0.008,
      "period_ms": 3200,
      "comment": "仅纵向缩放,锚点 meta.pivot(脚底)。禁止位移,amp_px 已废弃"
    },
    "bounce": {
      "comment": "说话弹跳,由RMS驱动",
      "max_px": 14,
      "attack_ms": 40,
      "release_ms": 180,
      "gain": 4.0
    },
    "drift": {
      "comment": "Perlin微漂移",
      "amp_px": 2.5,
      "speed": 0.3
    },
    "sway": {
      "comment": "整体轻微旋转摆动。默认关闭(0);需要时再开",
      "amp_deg": 0,
      "period_ms": 5200
    },
    "listening": {
      "comment": "Realtime VAD=用户说话中时的倾听姿态",
      "tilt_deg": 5,
      "blink_interval_scale": 0.7
    },
    "tilt": {
      "max_deg": 6,
      "stiffness": 120,
      "damping": 14
    }
  },
  "stickers": {
    "comment": "overlay通道,弹出于头部右上方,任意PNG即插即用",
    "anchor": {
      "x": 940,
      "y": 260
    },
    "default_duration_ms": 1800,
    "animation": {
      "in": "pop",
      "out": "fade"
    },
    "items": {
      "sweat_laugh": {
        "file": "stickers/sweat_laugh.png",
        "scale": 0.55
      }
    }
  },
  "layers": {
    "enabled": false,
    "comment": "头层切口548,与身体层原图内容形成13px重叠带(泡泡袖自550起)。重叠是接缝的美术解:小幅相对位移被头层覆盖,渲染层无需精确对齐公式。资产缺失回退单图层。",
    "body": "layered/body.png",
    "head_dir": "layered/head/",
    "cut_y": 535,
    "neck_pivot": {
      "x": 627,
      "y": 500
    },
    "note": "头层 y535~545 线性羽化渐隐(袖子起于y≈550,不得再下移);body.png 为AI整张生成的'头发盖脸'完整立绘,无拼接。接缝已量化验证:各角度突变强度低于原图天然基线",
    "feather_to_y": 545,
    "deprecated": "分层旋转歪头方案已弃用(头发撕裂+接缝问题)。改用poses整图切换。此节及layered/资产保留仅作参考,渲染器应走poses"
  },
  "poses": {
    "comment": "整图姿态切换(方向3)。front挂完整表情/口型/眨眼系统;其余姿态为整张固定立绘,说话时嘴型简化或不动,情绪表情不生效",
    "dir": "poses/",
    "default": "front",
    "foot_baseline_y": 1188,
    "list": {
      "front": {
        "file": "poses/front.png",
        "full_expression": true
      },
      "tilt_right": {
        "file": "poses/tilt_right.png",
        "full_expression": false,
        "mouth": "none"
      },
      "tilt_left": {
        "file": "poses/tilt_left.png",
        "full_expression": false,
        "mouth": "none"
      },
      "side_right": {
        "file": "poses/side_right.png",
        "full_expression": false,
        "mouth": "none"
      },
      "side_left": {
        "file": "poses/side_left.png",
        "full_expression": false,
        "mouth": "none"
      }
    },
    "transition": {
      "type": "fade",
      "ms": 180,
      "comment": "姿态间交叉淡化,避免硬跳"
    },
    "triggers": {
      "idle_random": {
        "enabled": true,
        "interval_ms": [
          45000,
          90000
        ],
        "poses": [
          "tilt_left",
          "tilt_right"
        ],
        "comment": "待机只随机摇头(tilt),不含侧身;约45~90s一次,停留2-4s后回front"
      },
      "manual": {
        "comment": "Monitor页可手动触发测试"
      },
      "emotion_hint": {
        "enabled": true,
        "map": {
          "shy": "tilt_left",
          "害羞": "tilt_left",
          "sad": "tilt_right",
          "难过": "tilt_right",
          "surprised": "side_right",
          "惊讶": "side_left",
          "happy": "front",
          "开心": "front",
          "angry": "front",
          "生气": "front",
          "upset": "front",
          "无语": "front"
        },
        "comment": "LLM [emotion:] 时顺带切姿态；也可用显式 [pose:] 覆盖"
      }
    },
    "note": "非front姿态期间:呼吸/漂移/摆动运动层照常作用于整图;口型和情绪表情暂停;姿态切回front恢复全部功能。歪头/侧身本身已画在图里,不再做分层旋转"
  }
}