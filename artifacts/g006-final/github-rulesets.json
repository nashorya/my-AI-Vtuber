[
  {
    "id": 18867292,
    "name": "Require Windows quality gate",
    "target": "branch",
    "enforcement": "active",
    "conditions": {
      "ref_name": {
        "include": ["~DEFAULT_BRANCH"],
        "exclude": []
      }
    },
    "rules": [
      {
        "type": "required_status_checks",
        "parameters": {
          "strict_required_status_checks_policy": true,
          "do_not_enforce_on_create": false,
          "required_status_checks": [
            {
              "context": "Locked restore, Release build, test, audit, and package"
            }
          ]
        }
      }
    ]
  }
]
